<!DOCTYPE html>
<html lang="es">
<head><%- include('partials/head', { title: 'Usuarios' }) %></head>
<body>
<div class="layout">
  <%- include('partials/sidebar', { page: 'usuarios' }) %>
  <main class="main">
    <div class="page-header"><h1>Usuarios — Consola superadmin</h1><button class="btn btn-primary" onclick="abrirModal()">+ Nuevo usuario</button></div>
    <div class="alert" id="alerta"></div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr><th>#</th><th>Nombre</th><th>Email</th><th>Rol</th><th>Creado</th><th>Acciones</th></tr></thead>
          <tbody id="tablaBody"><tr><td colspan="6"><div class="empty-state"><p>Cargando…</p></div></td></tr></tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<div class="modal-overlay" id="modal">
  <div class="modal-box" style="max-width:420px">
    <div class="modal-header"><h3>Nuevo usuario</h3><button class="modal-close" onclick="cerrarModal()">✕</button></div>
    <div class="alert" id="alertaModal"></div>
    <p style="margin-bottom:1rem;color:var(--text-soft);font-size:0.875rem">
      El usuario se crea como <strong>cajero</strong>. Para convertirlo en administrador del taller, usa el botón "Asignar admin" en la tabla.
    </p>
    <form id="formUsuario" onsubmit="guardarUsuario(event)">
      <div class="form-group" style="margin-bottom:1rem"><label>Nombre *</label><input type="text" id="nombre" required minlength="2"></div>
      <div class="form-group" style="margin-bottom:1rem"><label>Email *</label><input type="email" id="email" required></div>
      <div class="form-group" style="margin-bottom:1rem"><label>Contraseña *</label><input type="password" id="password" required minlength="8"></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="cerrarModal()">Cancelar</button>
        <button type="submit" class="btn btn-primary" id="btnGuardar">Crear usuario</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/app.js"></script>
<script src="/js/usuarios.js"></script>
</body>
</html>
