<!DOCTYPE html>
<html lang="es">
<head><%- include('partials/head', { title: 'Servicios' }) %></head>
<body>
<div class="layout">
  <%- include('partials/sidebar', { page: 'servicios' }) %>
  <main class="main">
    <div class="page-header"><h1>Catálogo de Servicios</h1><button class="btn btn-primary" onclick="abrirModal()">+ Nuevo servicio</button></div>
    <div class="alert" id="alerta"></div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr><th>#</th><th>Nombre</th><th>Costo</th><th>Creado</th><th>Acciones</th></tr></thead>
          <tbody id="tablaBody"><tr><td colspan="5"><div class="empty-state"><p>Cargando…</p></div></td></tr></tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<div class="modal-overlay" id="modal">
  <div class="modal-box" style="max-width:420px">
    <div class="modal-header"><h3 id="modalTitulo">Nuevo servicio</h3><button class="modal-close" onclick="cerrarModal()">✕</button></div>
    <div class="alert" id="alertaModal"></div>
    <form id="formServicio" onsubmit="guardarServicio(event)">
      <input type="hidden" id="servicioId">
      <div class="form-group" style="margin-bottom:1rem"><label>Nombre del servicio *</label><input type="text" id="nombre" required minlength="2"></div>
      <div class="form-group" style="margin-bottom:1rem"><label>Costo (CLP) *</label><input type="text" id="costo" required placeholder="100.000" oninput="maskCLP(this)" data-raw=""></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="cerrarModal()">Cancelar</button>
        <button type="submit" class="btn btn-primary" id="btnGuardar">Guardar</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/app.js"></script>
<script src="/js/servicios.js"></script>
</body>
</html>
